# LibreSpeed - Environment Variables
# Copy to app.env and customize

# Timezone
TZ=America/New_York

# Host settings
BASE_HOST_NAME=speedtest.example.com

# Application
APP_ORG_NAME=LibreSpeed
APP_ADMIN_PASS=changeme_admin_password

# Contact email shown on speed test page
EMAIL_SERVER_MAIL_FROM=no-reply@example.com

# Optional: ipinfo.io API key for geolocation
IPINFO_APIKEY=
